#!/bin/sh

# 1. 筛选出当前暂存的 Kotlin 文件（排除已删除的）
STAGED_FILES=$(git diff --cached --name-only --diff-filter=d | grep -E '\.kt[s]?$')

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# 2. 将多行文件名用逗号连接，符合 spotlessFiles 的格式需求
FILES_COMMA=$(echo "$STAGED_FILES" | paste -sd, -)

echo "--- Spotless: 正在格式化以下修改的文件 ---"
echo "$STAGED_FILES"
echo "----------------------------------------"

# 3. 运行 Spotless 增量格式化
./gradlew spotlessApply -PspotlessFiles="$FILES_COMMA"
GRADLE_EXIT_CODE=$?

if [ $GRADLE_EXIT_CODE -ne 0 ]; then
    echo "❌ 格式化或校验失败，请检查代码！"
    exit $GRADLE_EXIT_CODE
fi

# 4. 重新把经过格式化的文件放入暂存区
echo "$STAGED_FILES" | while read -r file; do
    if [ -f "$file" ]; then
        git add "$file"
    fi
done

echo "✅ 格式化完成并重新暂存！"
exit 0
